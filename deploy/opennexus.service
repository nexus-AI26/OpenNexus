[Unit]
Description=OpenNexus AI (Telegram + Web UI)
After=network.target

[Service]
Type=simple
User=opennexus
Group=opennexus
WorkingDirectory=/opt/opennexus
ExecStart=/opt/opennexus/venv/bin/python main.py all
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
